{
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Information",
        "Microsoft.Extensions.Http": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.json",
          "rollingInterval": "Day",
          "restrictedToMinimumLevel": "Warning",
          "retainedFileCountLimit": 30,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "OCREngine"
    }
  },
  "Hangfire": {
    "RedisConnection": "192.168.1.9:6379,abortConnect=false,password=MySecurePassword123",
    "DashboardPath": "/hangfire",
    "DashboardTitle": "OCREngine Background Jobs",
    "WorkerCount": 2
  },
  "LlmModels": {
    "Dots": {
      "ModelName": "dots-ocr",
      "ApiKey": "no-ApiKey",
      "BaseUrl": "https://quocdai125--dots-ocr-serve-dev.modal.run/v1",
      "Concurrency": 15
    },
    "Chandra": {
      "ModelName": "datalab-to/chandra",
      "ApiKey": "no-ApiKey",
      "BaseUrl": "https://quocdai125--chandra-ocr-vllm-serve-dev.modal.run/v1",
      "Concurrency": 30
    },
    "DeepSeek": {
      "ModelName": "deepseek-ocr2",
      "ApiKey": "no-ApiKey",
      "BaseUrl": "https://quocdai125--deepseek-ocr2-vllm-server-serve-dev.modal.run/v1",
      "Concurrency": 13
    }
  },
  "ExternalServices": {
    "DocOri": {
      "BaseUrl": "http://192.168.1.9:8001",
      "BatchSize": 5
    }
  }
}